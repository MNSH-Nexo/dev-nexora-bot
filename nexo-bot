_menu_sysinfo() {
  _banner
  echo -e "  ${BOLD}📊  System Info${RESET}"
  _line
  echo ""
  echo -e "  ${BOLD}OS:${RESET}"
  cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"' | awk '{print "  "$0}' || true
  uname -r | awk '{print "  Kernel: "$0}' || true
  echo ""
  echo -e "  ${BOLD}Containers:${RESET}"
  docker ps --format "  {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null | column -t || _warn "Docker not running."
  echo ""
  echo -e "  ${BOLD}Disk:${RESET}"
  df -h / | awk 'NR==2{printf "  Used: %s / %s  (%s free)\n", $3, $2, $4}'
  echo ""
  echo -e "  ${BOLD}Memory:${RESET}"
  free -h | awk '/^Mem:/{printf "  Used: %s / %s\n", $3, $2}'
  echo ""
  echo -e "  ${BOLD}CPU load:${RESET}"
  uptime | awk -F'load average:' '{print "  "$2}' || true
  echo ""
  echo -e "  ${BOLD}Docker volumes:${RESET}"
  docker volume ls --filter name=nexora 2>/dev/null | tail -n +2 | awk '{print "  "$2}' || true
  echo ""
  echo -e "  ${BOLD}Bot directory:${RESET}  $BOT_DIR"
  echo -e "  ${BOLD}DB mode:${RESET}        $( _use_postgres && echo "PostgreSQL" || echo "SQLite" )"
  if ! _use_postgres; then
    local _db; _db=$(_find_sqlite_db)
    [[ -n "$_db" ]] && echo -e "  ${BOLD}SQLite path:${RESET}    $_db  ($(ls -lh "$_db" | awk '{print $5}'))"
  fi
  echo -e "  ${BOLD}.env present:${RESET}   $( [[ -f "$ENV_FILE" ]] && echo -e "${GREEN}Yes${RESET}" || echo -e "${RED}No${RESET}" )"
  echo ""
  # وضعیت سرویس‌های systemd
  echo -e "  ${BOLD}Services:${RESET}"
  for svc in nexora-panel nginx; do
    if systemctl is-active "$svc" &>/dev/null; then
      echo -e "  ${GREEN}● $svc${RESET} — running"
    elif systemctl list-units --all 2>/dev/null | grep -q "$svc"; then
      echo -e "  ${RED}● $svc${RESET} — stopped"
    fi
  done
  echo ""
  _press
}

# ────────────────────────────────────────────────────────────────
#  SSL helpers (from v1.1 — unchanged)
# ────────────────────────────────────────────────────────────────
_ssl_certbot_ok() { hash -r 2>/dev/null || true; certbot --version &>/dev/null; }

_ssl_list_domains() {
  if [[ -d /etc/letsencrypt/live ]]; then
    local domains; domains=$(ls /etc/letsencrypt/live/ 2>/dev/null | grep -v "^README$" || true)
    if [[ -n "$domains" ]]; then
      echo -e "\n  ${BOLD}Installed certificates:${RESET}"
      while IFS= read -r d; do
        [[ -z "$d" ]] && continue
        local cert="/etc/letsencrypt/live/$d/fullchain.pem"
        local exp="unknown"
        [[ -f "$cert" ]] && exp=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null | sed 's/notAfter=//' || echo "unknown")
        echo -e "  ${GREEN}✔${RESET}  ${BOLD}$d${RESET}  ${DIM}(expires: $exp)${RESET}"
      done <<< "$domains"
    else
      echo -e "\n  ${DIM}No certificates found.${RESET}"
    fi
  else
    echo -e "\n  ${DIM}No certificates yet. Use [1] to get one.${RESET}"
  fi
}

_ssl_install_certbot() {
  if _ssl_certbot_ok; then _ok "certbot already installed."; return 0; fi
  _info "Installing certbot..."
  if command -v apt-get &>/dev/null; then
    DEBIAN_FRONTEND=noninteractive apt-get install -y certbot 2>&1 | grep -E "^(Setting up|certbot|E:)" || true
  elif command -v dnf &>/dev/null; then
    dnf install -y certbot 2>&1 | tail -3 || true
  else
    yum install -y certbot 2>&1 | tail -3 || true
  fi
  hash -r 2>/dev/null || true
  if ! _ssl_certbot_ok; then
    snap install --classic certbot 2>/dev/null && ln -sf /snap/bin/certbot /usr/bin/certbot 2>/dev/null || true
    hash -r 2>/dev/null || true
  fi
  _ssl_certbot_ok && _ok "certbot installed." || { _err "certbot install failed."; return 1; }
}

_ssl_get_cert() {
  local domain="$1" email="$2"
  echo ""
  _info "Obtaining certificate for: ${BOLD}$domain${RESET}"
  local server_ip domain_ip
  server_ip=$(curl -s --max-time 5 https://api.ipify.org 2>/dev/null || curl -s --max-time 5 https://ifconfig.me 2>/dev/null || echo "")
  domain_ip=$(getent hosts "$domain" 2>/dev/null | awk '{print $1}' | head -1 || dig +short "$domain" 2>/dev/null | grep -v '\.$' | tail -1 || echo "")
  if [[ -n "$server_ip" && -n "$domain_ip" ]]; then
    if [[ "$server_ip" != "$domain_ip" ]]; then
      _warn "DNS mismatch! Server: $server_ip / Domain: $domain_ip"
      read -rp "  Continue anyway? (y/N): " _c
      [[ "$_c" =~ ^[Yy]$ ]] || return 1
    else
      _ok "DNS OK — $domain → $domain_ip"
    fi
  fi
  local _stopped_nginx=false _stopped_apache=false
  if ss -tlnp 2>/dev/null | grep -q ':80 '; then
    _warn "Port 80 in use — stopping service temporarily..."
    systemctl is-active nginx  &>/dev/null && systemctl stop nginx  && _stopped_nginx=true  && _info "nginx stopped."
    systemctl is-active apache2 &>/dev/null && systemctl stop apache2 && _stopped_apache=true && _info "apache2 stopped."
  fi
  echo ""
  _info "Running certbot standalone..."
  certbot certonly --standalone --non-interactive --agree-tos --email "$email" \
    --domain "$domain" --preferred-challenges http 2>&1 | while IFS= read -r line; do echo -e "  ${DIM}$line${RESET}"; done
  local cert_ok=false
  [[ -f "/etc/letsencrypt/live/$domain/fullchain.pem" ]] && cert_ok=true
  [[ "$_stopped_nginx"  == "true" ]] && systemctl start nginx  2>/dev/null && _info "nginx restarted."
  [[ "$_stopped_apache" == "true" ]] && systemctl start apache2 2>/dev/null && _info "apache2 restarted."
  if [[ "$cert_ok" == "true" ]]; then
    _ok "Certificate obtained for ${BOLD}$domain${RESET} ✓"; return 0
  else
    _err "certbot failed. Check DNS, port 80, and rate limits."; return 1
  fi
}

_ssl_setup_nginx_proxy() {
  local domain="$1"
  local wh_port; wh_port=$(_env_read "$ENV_FILE" "WEBHOOK_PORT" "9988")
  command -v nginx &>/dev/null || {
    _info "Installing nginx..."
    command -v apt-get &>/dev/null && DEBIAN_FRONTEND=noninteractive apt-get install -y nginx 2>&1 | tail -3 || true
    command -v dnf &>/dev/null && dnf install -y nginx 2>&1 | tail -3 || true
  }
  local conf_file="/etc/nginx/conf.d/nexora-webhook.conf"
  cat > "$conf_file" <<NGINXCONF
server {
    listen 80;
    server_name ${domain};
    location /.well-known/acme-challenge/ { root /var/www/html; }
    location / { return 301 https://\$host\$request_uri; }
}
server {
    listen 443 ssl;
    server_name ${domain};
    ssl_certificate     /etc/letsencrypt/live/${domain}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${domain}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    location /webhook/ {
        proxy_pass http://127.0.0.1:${wh_port};
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_read_timeout 15s;
    }
    location /health { proxy_pass http://127.0.0.1:${wh_port}/health; }
    location / { return 404; }
}
NGINXCONF
  nginx -t 2>/dev/null && systemctl enable nginx --now 2>/dev/null && systemctl reload nginx 2>/dev/null \
    && _ok "nginx proxy configured → https://${domain}/webhook/" || { _err "nginx config failed."; return 1; }
