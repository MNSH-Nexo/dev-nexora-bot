set -uo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BOT_DIR="$(dirname "$SCRIPT_PATH")"
ENV_FILE="$BOT_DIR/.env"
COMPOSE_FILE="$BOT_DIR/docker-compose.yml"

PANEL_SYSTEMD_SERVICE="nexora-panel"
PANEL_DIR="/opt/nexora-panel"
PANEL_ENV_LOCAL="$PANEL_DIR/.env.local"
PANEL_ENV_KEY_ENABLED="WEB_PANEL_ENABLED"
PANEL_ENV_KEY_PATH="WEB_PANEL_PATH"
PANEL_ENV_KEY_USER="WEB_PANEL_USER"
PANEL_ENV_KEY_PASS="WEB_PANEL_PASS"
PANEL_ENV_KEY_PORT="WEB_PANEL_PORT"

# ── Colors ────────────────────────────────────────────────────
RED='\033[0;31m';    GREEN='\033[0;32m';  YELLOW='\033[1;33m'
BLUE='\033[0;34m';   CYAN='\033[0;36m';  BOLD='\033[1m'
DIM='\033[2m';       RESET='\033[0m'

_use_postgres() {
  [[ -f "$ENV_FILE" ]] && grep -q "^USE_POSTGRES=true" "$ENV_FILE"
}

_dc() {
  if _use_postgres; then
    docker compose -f "$COMPOSE_FILE" --profile postgres "$@"
  else
    docker compose -f "$COMPOSE_FILE" "$@"
  fi
}

_banner() {
  clear
