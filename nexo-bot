# ────────────────────────────────────────────────────────────────
#  Web Panel helpers
# ────────────────────────────────────────────────────────────────
_gen_webpath() {
  local chars='abcdefghijklmnopqrstuvwxyz0123456789'
  local result=""
  for _ in $(seq 1 12); do result+="${chars:RANDOM%${#chars}:1}"; done
  echo "/${result}"
}

_panel_install_nodejs() {
  if command -v node &>/dev/null; then
    local _ver; _ver=$(node --version 2>/dev/null | tr -d 'v' | cut -d. -f1)
    (( _ver >= 20 )) && { _ok "Node.js $(node --version) already installed."; return 0; }
    _warn "Node.js $(node --version) too old — upgrading to v20..."
  else
    _info "Installing Node.js 20..."
  fi
  local _pkg="yum"
  command -v apt-get &>/dev/null && _pkg="apt"
  command -v dnf &>/dev/null && _pkg="dnf"
  case "$_pkg" in
    apt) curl -fsSL https://deb.nodesource.com/setup_20.x | bash - &>/dev/null; apt-get install -y nodejs &>/dev/null ;;
    dnf) curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - &>/dev/null; dnf install -y nodejs &>/dev/null ;;
    *)   curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - &>/dev/null; yum install -y nodejs &>/dev/null ;;
  esac
  command -v node &>/dev/null && _ok "Node.js $(node --version) installed." || { _err "Node.js install failed."; return 1; }
}

_panel_install_pnpm() {
  command -v pnpm &>/dev/null && { _ok "pnpm $(pnpm --version) ready."; return 0; }
  _info "Installing pnpm..."
  npm install -g pnpm@latest &>/dev/null
  command -v pnpm &>/dev/null && _ok "pnpm installed." || { _err "pnpm install failed."; return 1; }
}

_read_bot_env_vars() {
  _BOT_TOKEN=$(_env_read "$ENV_FILE" "BOT_TOKEN" "")
  _ADMIN_IDS=$(_env_read "$ENV_FILE" "ADMIN_IDS" "")
  _PANEL_URL=$(_env_read "$ENV_FILE" "PANEL_URL" "")
  _PANEL_USERNAME=$(_env_read "$ENV_FILE" "PANEL_USERNAME" "admin")
  _PANEL_PASSWORD=$(_env_read "$ENV_FILE" "PANEL_PASSWORD" "")
  _SUB_PORT=$(_env_read "$ENV_FILE" "SUB_PORT" "")
  _WEBHOOK_PORT=$(_env_read "$ENV_FILE" "WEBHOOK_PORT" "9988")
  # مسیر DB
  _BOT_DB_PATH="/opt/nexora-bot/data/bot_data.db"
  local _vol_db="/var/lib/docker/volumes/nexora_bot_data/_data/bot_data.db"
  local _std_db="/opt/nexora-bot/data/bot_data.db"
  [[ -f "$_vol_db" ]] && _BOT_DB_PATH="$_vol_db"
  [[ -f "$_std_db" ]] && _BOT_DB_PATH="$_std_db"
}

_write_panel_env() {
  local _wpath="$1" _wuser="$2" _wpass="$3" _wport="$4" _wenabled="${5:-true}"
  _read_bot_env_vars
  mkdir -p "$PANEL_DIR"
  cat > "$PANEL_ENV_LOCAL" <<ENVEOF
NODE_ENV=production
WEB_PANEL_ENABLED=${_wenabled}
WEB_PANEL_PATH=${_wpath}
WEB_PANEL_USER=${_wuser}
WEB_PANEL_PASS=${_wpass}
WEB_PANEL_PORT=${_wport}
BOT_TOKEN=${_BOT_TOKEN}
ADMIN_IDS=${_ADMIN_IDS}
PANEL_URL=${_PANEL_URL}
PANEL_USERNAME=${_PANEL_USERNAME}
PANEL_PASSWORD=${_PANEL_PASSWORD}
SUB_PORT=${_SUB_PORT}
WEBHOOK_PORT=${_WEBHOOK_PORT}
BOT_DB_PATH=${_BOT_DB_PATH}
ENVEOF
  chmod 600 "$PANEL_ENV_LOCAL"
  _ok "Panel .env.local written (bot vars synced)."
}

_panel_full_install() {
  local _wpath="$1" _wuser="$2" _wpass="$3" _wport="$4"
  local _saved_dir; _saved_dir="$BOT_DIR"
  echo ""
  command -v rsync &>/dev/null || apt-get install -y -qq rsync 2>/dev/null || yum install -y rsync 2>/dev/null || true
  _info "Step 1/5 — Installing Node.js..."
  _panel_install_nodejs || { cd "$_saved_dir" 2>/dev/null; return 1; }
  _info "Step 2/5 — Installing pnpm..."
  _panel_install_pnpm || { cd "$_saved_dir" 2>/dev/null; return 1; }
  _info "Step 3/5 — Copying panel source..."
  local _panel_src="$BOT_DIR/.."

  # ── روش ۱: فایل‌های پنل یک لول بالاتر (ساختار dev / git clone) ──
  if [[ -f "$_panel_src/package.json" ]]; then
    rm -rf "$PANEL_DIR"
    mkdir -p "$PANEL_DIR"
    rsync -a --exclude='.git' --exclude='bot/' --exclude='node_modules/' \
      --exclude='.next/' --exclude='attachements/' "$_panel_src/" "$PANEL_DIR/"
    _ok "Source copied from parent directory."

  # ── روش ۲: nexora-panel.zip کنار nexo-bot / در BOT_DIR ──────────
  else
    local _pzip=""
    for _c in \
        "$BOT_DIR/nexora-panel.zip" \
        "$(dirname "$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "$0")")/nexora-panel.zip" \
        "/tmp/nexora-panel.zip"; do
      [[ -f "$_c" ]] && { _pzip="$_c"; break; }
    done

    if [[ -z "$_pzip" ]]; then
      _err "Panel source not found. Place nexora-panel.zip next to nexo-bot and retry."
      cd "$_saved_dir" 2>/dev/null; return 1
    fi

    _info "Extracting panel from: $_pzip"
    command -v unzip &>/dev/null || apt-get install -y -qq unzip 2>/dev/null || yum install -y unzip 2>/dev/null || true
    rm -rf "$PANEL_DIR"
    mkdir -p "$PANEL_DIR"
    unzip -q "$_pzip" -d "$PANEL_DIR"

    # اگه unzip یک زیرپوشه ساخت، محتوا رو به بالا بیار
    local _inner
    _inner=$(find "$PANEL_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | head -1)
    if [[ -n "$_inner" && -f "$_inner/package.json" ]]; then
      rsync -a "$_inner/" "$PANEL_DIR/"
      rm -rf "$_inner"
    fi

    if [[ ! -f "$PANEL_DIR/package.json" ]]; then
      _err "Invalid nexora-panel.zip — package.json not found after extraction"
      cd "$_saved_dir" 2>/dev/null; return 1
    fi
    _ok "Source extracted from zip."
  fi
  _info "Step 4/5 — Installing dependencies..."
  ( cd "$PANEL_DIR" && pnpm install --no-frozen-lockfile --ignore-scripts 2>&1 | tail -5 ) \
    || { _err "pnpm install failed."; cd "$_saved_dir" 2>/dev/null; return 1; }
  ( cd "$PANEL_DIR" && pnpm rebuild better-sqlite3 2>&1 | tail -3 ) || true
  _info "Step 5/5 — Building panel (production)..."
  ( cd "$PANEL_DIR" && NODE_ENV=production pnpm build 2>&1 | tail -8 ) \
    || { _err "pnpm build failed."; cd "$_saved_dir" 2>/dev/null; return 1; }
  _ok "Build complete."
  _write_panel_env "$_wpath" "$_wuser" "$_wpass" "$_wport" "true"
  local _pnpm_bin; _pnpm_bin=$(command -v pnpm)
  cat > "/etc/systemd/system/${PANEL_SYSTEMD_SERVICE}.service" <<SVCEOF
[Unit]
Description=Nexora Web Admin Panel
After=network.target

[Service]
Type=simple
WorkingDirectory=${PANEL_DIR}
ExecStart=${_pnpm_bin} start
Restart=always
RestartSec=5
EnvironmentFile=${PANEL_ENV_LOCAL}
Environment=NODE_ENV=production
Environment=PORT=${_wport}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
SVCEOF
  systemctl daemon-reload
  systemctl enable "$PANEL_SYSTEMD_SERVICE" &>/dev/null
  systemctl restart "$PANEL_SYSTEMD_SERVICE"
  sleep 4
  systemctl is-active "$PANEL_SYSTEMD_SERVICE" &>/dev/null \
    && _ok "Panel service is running!" \
    || _warn "Service issue. Check: journalctl -u ${PANEL_SYSTEMD_SERVICE} -n 30"
  command -v ufw &>/dev/null && ufw status 2>/dev/null | grep -q "active" \
    && ufw allow "${_wport}/tcp" &>/dev/null && _ok "UFW: port ${_wport} opened." || true
  command -v firewall-cmd &>/dev/null \
    && firewall-cmd --permanent --add-port="${_wport}/tcp" &>/dev/null \
    && firewall-cmd --reload &>/dev/null && _ok "firewalld: port ${_wport} opened." || true
  cd "$_saved_dir" 2>/dev/null; return 0
}

_panel_apply_env() {
  command -v systemctl &>/dev/null || return 0
  [[ -f "/etc/systemd/system/${PANEL_SYSTEMD_SERVICE}.service" ]] || return 0
  local _wpath _wuser _wpass _wport _wenabled
  local _cfg_src; _cfg_src=$( [[ -f "$PANEL_ENV_LOCAL" ]] && echo "$PANEL_ENV_LOCAL" || echo "$ENV_FILE" )
  _wenabled=$(_env_read "$_cfg_src" "WEB_PANEL_ENABLED" "true")
  _wpath=$(_env_read "$_cfg_src"    "WEB_PANEL_PATH"    "/nexora")
  _wuser=$(_env_read "$_cfg_src"    "WEB_PANEL_USER"    "admin")
  _wpass=$(_env_read "$_cfg_src"    "WEB_PANEL_PASS"    "")
  _wport=$(_env_read "$_cfg_src"    "WEB_PANEL_PORT"    "3000")
  _write_panel_env "$_wpath" "$_wuser" "$_wpass" "$_wport" "$_wenabled"
  # حذف PORT تکراری از service unit
  sed -i '/^Environment=PORT=/d' "/etc/systemd/system/${PANEL_SYSTEMD_SERVICE}.service" 2>/dev/null || true
  sed -i "/^Environment=NODE_ENV=/a Environment=PORT=${_wport}" \
    "/etc/systemd/system/${PANEL_SYSTEMD_SERVICE}.service" 2>/dev/null || true
  systemctl daemon-reload
  if [[ "$_wenabled" == "true" ]]; then
    systemctl restart "$PANEL_SYSTEMD_SERVICE" 2>/dev/null \
      && _ok "Panel service restarted." || _warn "Could not restart panel."
  else
    systemctl stop "$PANEL_SYSTEMD_SERVICE" 2>/dev/null && _ok "Panel stopped." || true
  fi
}

