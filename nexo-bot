REPO_STABLE="https://github.com/MNSH-Nexo/Nexora-Bot-Panel.git"
REPO_BETA="https://github.com/MNSH-Nexo/Dev-Nexora-Bot.git"

# نمایش نسخه فعلی از git log
_update_show_version() {
  echo ""
  echo -e "  ${BOLD}Current version:${RESET}"
  if [[ -d "$BOT_DIR/.git" ]]; then
    local _commit _date _remote
    _commit=$(git -C "$BOT_DIR" log --oneline -1 2>/dev/null || echo "unknown")
    _date=$(git -C "$BOT_DIR" log -1 --format="%ci" 2>/dev/null | cut -d' ' -f1 || echo "")
    _remote=$(git -C "$BOT_DIR" remote get-url origin 2>/dev/null || echo "unknown")
    echo -e "  ${CYAN}Commit  :${RESET} $_commit"
    [[ -n "$_date" ]] && echo -e "  ${CYAN}Date    :${RESET} $_date"
    echo -e "  ${CYAN}Remote  :${RESET} $_remote"
  else
    _warn "No git history found in $BOT_DIR"
  fi
  echo ""
}

# انتخاب مخزن توسط کاربر
_update_pick_repo() {
  PICKED_REPO=""
  PICKED_REPO_NAME=""
  echo -e "  ${BOLD}Select update source:${RESET}"
  echo ""
  echo -e "  ${BOLD}[1]${RESET}  ${GREEN}Stable${RESET}  — Nexora-Bot-Panel  ${DIM}(recommended — production)${RESET}"
  echo -e "       ${DIM}${REPO_STABLE}${RESET}"
  echo ""
  echo -e "  ${BOLD}[2]${RESET}  ${YELLOW}Beta${RESET}    — Dev-Nexora-Bot    ${DIM}(latest features — may be unstable)${RESET}"
  echo -e "       ${DIM}${REPO_BETA}${RESET}"
