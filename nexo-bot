main() {
  while true; do
    _banner
    _status_bar
    _panel_status
    echo ""
    echo -e "  ${BOLD}[1]${RESET}  🤖  Bot Control      (start / stop / restart / logs)"
    echo -e "  ${BOLD}[2]${RESET}  ⚙️   Configuration    (edit .env / validate)"
    echo -e "  ${BOLD}[3]${RESET}  🗄   Database         (info / migrate / backup)"
    echo -e "  ${BOLD}[4]${RESET}  💾  Backup & Restore"
    echo -e "  ${BOLD}[5]${RESET}  📊  System Info"
    echo -e "  ${BOLD}[6]${RESET}  ${RED}🗑   Uninstall${RESET}        (remove everything)"
    echo -e "  ${BOLD}[7]${RESET}  🔒  SSL Manager       (Let's Encrypt certificate)"
    echo -e "  ${BOLD}[8]${RESET}  🔗  Webhook Manager   (manage webhook URLs)"
    echo -e "  ${BOLD}[9]${RESET}  🌐  Web Panel         (enable / manage admin panel)"
    echo -e "  ${BOLD}[U]${RESET}  ${GREEN}🔄  Update${RESET}           (bot + panel — data & settings kept)"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Exit${RESET}"
    _line
    echo -e "  ${DIM}Dir: $BOT_DIR${RESET}"
    echo ""
    read -rp "  Choose: " ch
    case $ch in
      1) _menu_control ;;
      2) _menu_config ;;
      3) _menu_database ;;
      4) _menu_backup ;;
      5) _menu_sysinfo ;;
      6) _menu_uninstall ;;
      7) _menu_ssl ;;
      8) _menu_webhook ;;
      9) _menu_webpanel ;;
      u|U) _menu_update ;;
      0) echo ""; exit 0 ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

main
