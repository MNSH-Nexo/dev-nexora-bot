  echo "  ████╗  ██║██╔════╝╚██╗██╔╝██╔═══██╗██╔══██╗██╔══██╗"
  echo "  ██╔██╗ ██║█████╗   ╚███╔╝ ██║   ██║██████╔╝███████║"
  echo "  ██║╚██╗██║██╔══╝   ██╔██╗ ██║   ██║██╔══██╗██╔══██║"
  echo "  ██║ ╚████║███████╗██╔╝ ██╗╚██████╔╝██║  ██║██║  ██║"
  echo "  ╚═╝  ╚═══╝╚══════╝╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝"
  echo -e "${RESET}${DIM}                 VPN Bot Management CLI v2.1${RESET}"
  echo -e "${DIM}         Built by MNSH-Nexo · github.com/MNSH-Nexo${RESET}"
  echo ""
  echo -e "  ${DIM}┌─────────────────────────────────────────────────┐${RESET}"
  echo -e "  ${DIM}│${RESET}  ${YELLOW}☕ Donate (TRX / TRC20)${RESET}                          ${DIM}│${RESET}"
  echo -e "  ${DIM}│${RESET}  ${CYAN}TGzhHsfta8MdMPNzpexnqFCUiux7T1H5Ng${RESET}          ${DIM}│${RESET}"
  echo -e "  ${DIM}└─────────────────────────────────────────────────┘${RESET}"
  echo ""
}

_line()  { echo -e "${DIM}────────────────────────────────────────────────────${RESET}"; }
_ok()    { echo -e "  ${GREEN}✔${RESET}  $*"; }
_warn()  { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
_err()   { echo -e "  ${RED}✘${RESET}  $*"; }
_info()  { echo -e "  ${CYAN}ℹ${RESET}  $*"; }
_press() { echo -e "\n${DIM}  Press Enter to continue...${RESET}"; read -r; }

_require_compose() {
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    _err "docker-compose.yml not found in: $BOT_DIR"; _press; return 1
  fi
}

# ── خواندن یک مقدار از هر فایل .env ──────────────────────────
_env_read() {
  local file="$1" key="$2" default="${3:-}"
  [[ -f "$file" ]] || { echo "$default"; return; }
  local val; val=$(grep "^${key}=" "$file" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
  echo "${val:-$default}"
}

# ── نوشتن/بروزرسانی یک کلید در فایل .env ─────────────────────
_env_set() {
  local key="$1" val="$2" file="${3:-$ENV_FILE}"
  if grep -q "^${key}=" "$file" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=${val}|" "$file"
  else
    echo "${key}=${val}" >> "$file"
  fi
}

# ── وضعیت ربات ────────────────────────────────────────────────
_status_bar() {
  local bot_status
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "nexora_bot"; then
    bot_status="${GREEN}● Running${RESET}"
  else
    bot_status="${RED}● Stopped${RESET}"
  fi
  if _use_postgres; then
    local db_status
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "nexora_postgres"; then
      db_status="${GREEN}● Running${RESET}"
    else
      db_status="${YELLOW}● Stopped${RESET}"
    fi
    echo -e "  Bot: $bot_status    DB (PostgreSQL): $db_status"
  else
    echo -e "  Bot: $bot_status    DB: ${DIM}SQLite${RESET}"
  fi
}

# ── وضعیت وب‌پنل (از .env.local پنل — نه .env ربات) ───────────
_panel_status() {
  local _enabled _path _port _user _svc_status

  # اول .env.local پنل، اگه نبود .env ربات
  if [[ -f "$PANEL_ENV_LOCAL" ]]; then
    _enabled=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_ENABLED" "false")
    _path=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PATH" "/nexora")
    _port=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")
    _user=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_USER" "admin")
  else
    _enabled=$(_env_read "$ENV_FILE" "WEB_PANEL_ENABLED" "false")
    _path=$(_env_read "$ENV_FILE" "WEB_PANEL_PATH" "/nexora")
    _port=$(_env_read "$ENV_FILE" "WEB_PANEL_PORT" "3000")
    _user=$(_env_read "$ENV_FILE" "WEB_PANEL_USER" "admin")
  fi

  if systemctl is-active "$PANEL_SYSTEMD_SERVICE" &>/dev/null; then
    _svc_status="${GREEN}● Running${RESET}"
  elif [[ "$_enabled" == "true" ]]; then
    _svc_status="${YELLOW}● Stopped${RESET}"
  else
    _svc_status="${RED}● Disabled${RESET}"
  fi

  if [[ "$_enabled" == "true" ]]; then
    echo -e "  Panel: $_svc_status    Path: ${CYAN}${_path}${RESET}    Port: ${CYAN}${_port}${RESET}    User: ${CYAN}${_user}${RESET}"
  else
    echo -e "  Panel: $_svc_status"
  fi
}

_panel_is_enabled() {
  if [[ -f "$PANEL_ENV_LOCAL" ]]; then
    grep -q "^WEB_PANEL_ENABLED=true" "$PANEL_ENV_LOCAL" 2>/dev/null
  else
    [[ -f "$ENV_FILE" ]] && grep -q "^${PANEL_ENV_KEY_ENABLED}=true" "$ENV_FILE"
  fi
}

# ── یافتن مسیر SQLite DB ──────────────────────────────────────
_find_sqlite_db() {
  local candidates=(
    "/var/lib/docker/volumes/nexora_bot_data/_data/bot_data.db"
    "/opt/nexora-bot/data/bot_data.db"
    "$BOT_DIR/bot_data.db"
  )
  for p in "${candidates[@]}"; do
    [[ -f "$p" ]] && { echo "$p"; return; }
  done
  # جستجو در docker volume
  local vol_path; vol_path=$(docker volume inspect nexora_bot_data \
    --format '{{.Mountpoint}}' 2>/dev/null || echo "")
  [[ -n "$vol_path" && -f "$vol_path/bot_data.db" ]] && echo "$vol_path/bot_data.db"
}

# ── اجرای SQL روی SQLite DB داخل Docker volume ────────────────
_sqlite_exec() {
  local sql="$1"
  local db_path; db_path=$(_find_sqlite_db)
  if [[ -z "$db_path" ]]; then
    _err "SQLite DB not found. Start the bot first."; return 1
  fi
  # اگه sqlite3 نصب باشه مستقیم اجرا کن
  if command -v sqlite3 &>/dev/null; then
    sqlite3 "$db_path" "$sql"
  elif command -v docker &>/dev/null; then
    # از طریق container ربات
    docker exec nexora_bot sqlite3 /app/bot_data.db "$sql" 2>/dev/null || \
      { _err "sqlite3 not available. Install it: apt install sqlite3"; return 1; }
  else
    _err "sqlite3 not installed. Run: apt install sqlite3"; return 1
  fi
}

# ────────────────────────────────────────────────────────────────
#  [1] Bot Control
# ────────────────────────────────────────────────────────────────
_menu_control() {
  while true; do
    _banner
    echo -e "  ${BOLD}🤖  Bot Control${RESET}"
    _status_bar
    _line
    echo -e "  ${BOLD}[1]${RESET}  Start"
    echo -e "  ${BOLD}[2]${RESET}  Stop"
    echo -e "  ${BOLD}[3]${RESET}  Restart  (apply .env changes)"
    echo -e "  ${BOLD}[4]${RESET}  Rebuild image + restart  (after code changes)"
    echo -e "  ${BOLD}[5]${RESET}  Live logs  (Ctrl+C to exit)"
    echo -e "  ${BOLD}[6]${RESET}  Last 200 lines of logs"
    echo -e "  ${BOLD}[7]${RESET}  Show bot errors only"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1) _require_compose && _dc up -d && _ok "Bot started." && _press ;;
      2) _require_compose && _dc stop bot && _ok "Bot stopped." && _press ;;
      3) _require_compose
         _info "Recreating container to apply .env changes..."
         _dc up -d --force-recreate bot
         _ok "Restarted — .env changes applied." && _press ;;
      4) _require_compose
         _info "Rebuilding image..."
         _dc build --no-cache bot
         _dc up -d --force-recreate bot
         _ok "Done." && _press ;;
      5) _require_compose && _dc logs -f bot ;;
      6) _require_compose && _dc logs --tail=200 bot && _press ;;
      7) _require_compose && _dc logs --tail=300 bot 2>&1 | grep -i "error\|exception\|traceback\|critical" | tail -50 && _press ;;
      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

# ────────────────────────────────────────────────────────────────
#  [2] Configuration
# ────────────────────────────────────────────────────────────────
_menu_config() {
  while true; do
    _banner
    echo -e "  ${BOLD}⚙️   Configuration${RESET}"
    _line
    echo -e "  ${BOLD}[1]${RESET}  Edit .env               (main config)"
    echo -e "  ${BOLD}[2]${RESET}  View .env               (read-only)"
    echo -e "  ${BOLD}[3]${RESET}  Show key settings        (tokens hidden)"
    echo -e "  ${BOLD}[4]${RESET}  Edit docker-compose.yml"
    echo -e "  ${BOLD}[5]${RESET}  Validate .env            (check required fields)"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1)
        [[ ! -f "$ENV_FILE" ]] && cp "$BOT_DIR/.env.example" "$ENV_FILE" 2>/dev/null && _info "Created .env from example."
        ${EDITOR:-nano} "$ENV_FILE"
        echo ""
        _ok "Saved."
        _warn "Changes take effect ONLY after recreating container (option [3] in Bot Control)."
        read -rp "  Apply changes now? Recreate container? (Y/n): " _yn
        _yn="${_yn:-Y}"
        if [[ "$_yn" =~ ^[Yy]$ ]]; then
          _require_compose
          _dc up -d --force-recreate bot
          _ok "Done — new .env is now active."
        fi
        _press ;;
      2)
        [[ -f "$ENV_FILE" ]] && { echo ""; cat "$ENV_FILE"; _press; } \
          || { _err ".env not found."; _press; } ;;
      3)
        [[ -f "$ENV_FILE" ]] || { _err ".env not found."; _press; continue; }
        echo ""
        echo -e "  ${BOLD}Key settings (secrets hidden):${RESET}"
        echo ""
        local _keys=(BOT_TOKEN ADMIN_IDS PANEL_URL PANEL_USERNAME PANEL_PASSWORD
                     SUB_PORT WEBHOOK_PORT NOWPAYMENTS_API_KEY MAXELPAY_API_KEY
                     ADMIN_SECRET USE_POSTGRES DEFAULT_TRAFFIC_GB DEFAULT_SUBSCRIPTION_DAYS)
        for _k in "${_keys[@]}"; do
          local _v; _v=$(grep "^${_k}=" "$ENV_FILE" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
          [[ -z "$_v" ]] && continue
          case "$_k" in
            BOT_TOKEN|PANEL_PASSWORD|NOWPAYMENTS_API_KEY|MAXELPAY_API_KEY|ADMIN_SECRET)
              _v="***hidden***" ;;
          esac
          echo -e "  ${CYAN}${_k}${RESET} = ${_v}"
        done
        _press ;;
      4) ${EDITOR:-nano} "$COMPOSE_FILE" && _press ;;
      5)
        echo ""
        echo -e "  ${BOLD}Validating .env...${RESET}"
        echo ""
        local _required=(BOT_TOKEN ADMIN_IDS PANEL_URL PANEL_USERNAME PANEL_PASSWORD)
        local _ok_count=0 _err_count=0
        for _k in "${_required[@]}"; do
          local _v; _v=$(grep "^${_k}=" "$ENV_FILE" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
          if [[ -n "$_v" ]]; then
            _ok "$_k = ${_k/*PASSWORD*/***hidden***}"
            (( _ok_count++ )) || true
          else
            _err "$_k is MISSING or empty"
            (( _err_count++ )) || true
          fi
        done
        echo ""
        if (( _err_count == 0 )); then
          _ok "All required fields are set."
        else
          _warn "$_err_count required field(s) missing — bot may not work."
        fi
        _press ;;
      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

# ────────────────────────────────────────────────────────────────
#  [3] Database
# ────────────────────────────────────────────────────────────────
_menu_database() {
  while true; do
    _banner
    echo -e "  ${BOLD}🗄   Database${RESET}"
    _line
    if _use_postgres; then
      echo -e "  ${DIM}Mode: PostgreSQL${RESET}"
      echo -e "  ${BOLD}[1]${RESET}  Start database"
      echo -e "  ${BOLD}[2]${RESET}  Stop database"
      echo -e "  ${BOLD}[3]${RESET}  View database logs"
      echo -e "  ${BOLD}[4]${RESET}  Open psql shell"
      echo -e "  ${BOLD}[5]${RESET}  Apply migrations  (add missing columns)"
      echo -e "  ${BOLD}[6]${RESET}  Export tables to CSV"
    else
      echo -e "  ${DIM}Mode: SQLite${RESET}"
      echo -e "  ${BOLD}[1]${RESET}  Show DB info  (path, size, table counts)"
      echo -e "  ${BOLD}[2]${RESET}  Apply migrations  (add missing columns)"
      echo -e "  ${BOLD}[3]${RESET}  Backup DB  (copy to /root/)"
      echo -e "  ${BOLD}[4]${RESET}  Open SQLite shell  (read-only query)"
      echo -e "  ${BOLD}[5]${RESET}  Show recent users  (last 10)"
      echo -e "  ${BOLD}[6]${RESET}  Show active subscriptions count"
    fi
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch

    if _use_postgres; then
      case $ch in
        1) _require_compose && _dc up -d db && _ok "Database started." && _press ;;
        2) _require_compose && _dc stop db && _ok "Database stopped." && _press ;;
        3) _require_compose && _dc logs --tail=80 db && _press ;;
        4) _info "Connecting to psql..."
           _dc exec db psql -U botuser -d vpn_bot; _press ;;
        5)
          _info "Running PostgreSQL migrations..."
          _dc exec db psql -U botuser -d vpn_bot -c \
            "ALTER TABLE subscriptions ADD COLUMN IF NOT EXISTS limit_ip INTEGER NOT NULL DEFAULT 0;
             ALTER TABLE subscriptions ADD COLUMN IF NOT EXISTS warned_7d BOOLEAN NOT NULL DEFAULT FALSE;
             ALTER TABLE subscriptions ADD COLUMN IF NOT EXISTS warned_3d BOOLEAN NOT NULL DEFAULT FALSE;
             ALTER TABLE subscriptions ADD COLUMN IF NOT EXISTS warned_1d BOOLEAN NOT NULL DEFAULT FALSE;
             ALTER TABLE users ADD COLUMN IF NOT EXISTS referral_code VARCHAR(16);
             ALTER TABLE users ADD COLUMN IF NOT EXISTS referred_by INTEGER;
             CREATE TABLE IF NOT EXISTS plans (
               id SERIAL PRIMARY KEY, name VARCHAR(64) NOT NULL,
               traffic_gb INTEGER NOT NULL DEFAULT 0,
               duration_days INTEGER NOT NULL DEFAULT 30,
               price_usdt FLOAT NOT NULL,
               limit_ip INTEGER NOT NULL DEFAULT 0,
               inbound_ids VARCHAR(256) NOT NULL DEFAULT '',
               is_active BOOLEAN NOT NULL DEFAULT TRUE,
               sort_order INTEGER NOT NULL DEFAULT 0,
               created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
               updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
             );
             CREATE TABLE IF NOT EXISTS pending_actions (
               id SERIAL PRIMARY KEY, type VARCHAR(64) NOT NULL,
               payload TEXT NOT NULL DEFAULT '{}',
               created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
             );" \
          && _ok "Migrations done." || _warn "Some may already exist — that's OK."
          _press ;;
        6)
          _info "Exporting tables to CSV..."
          local _ts; _ts=$(date +%Y%m%d_%H%M)
          _dc exec -T db psql -U botuser -d vpn_bot \
            -c "\COPY users TO '/tmp/users_${_ts}.csv' CSV HEADER"  2>/dev/null || true
          _dc exec -T db psql -U botuser -d vpn_bot \
            -c "\COPY subscriptions TO '/tmp/subs_${_ts}.csv' CSV HEADER" 2>/dev/null || true
          _ok "Exported. Check docker exec output above."
          _press ;;
        0) return ;;
        *) _warn "Invalid option." ;;
      esac
    else
      # SQLite mode
      case $ch in
        1)
          local _db; _db=$(_find_sqlite_db)
          echo ""
          if [[ -n "$_db" ]]; then
            _ok "DB path: $_db"
            ls -lh "$_db"
            echo ""
            if command -v sqlite3 &>/dev/null; then
              echo -e "  ${BOLD}Table row counts:${RESET}"
              local tables=(users subscriptions payments tickets ticket_messages plans discount_codes admin_settings pending_actions)
              for t in "${tables[@]}"; do
                local cnt; cnt=$(sqlite3 "$_db" "SELECT COUNT(*) FROM $t;" 2>/dev/null || echo "N/A")
                echo -e "  ${DIM}$t${RESET}: $cnt"
              done
            fi
          else
            _warn "SQLite file not found. Start the bot first."
          fi
          _press ;;
        2)
          local _db2; _db2=$(_find_sqlite_db)
          [[ -z "$_db2" ]] && { _err "DB not found."; _press; continue; }
          _info "Applying SQLite migrations..."
          if command -v sqlite3 &>/dev/null; then
            sqlite3 "$_db2" \
              "ALTER TABLE subscriptions ADD COLUMN limit_ip INTEGER NOT NULL DEFAULT 0;" 2>/dev/null || true
            sqlite3 "$_db2" \
              "ALTER TABLE subscriptions ADD COLUMN warned_7d INTEGER NOT NULL DEFAULT 0;" 2>/dev/null || true
            sqlite3 "$_db2" \
              "ALTER TABLE subscriptions ADD COLUMN warned_3d INTEGER NOT NULL DEFAULT 0;" 2>/dev/null || true
            sqlite3 "$_db2" \
              "ALTER TABLE subscriptions ADD COLUMN warned_1d INTEGER NOT NULL DEFAULT 0;" 2>/dev/null || true
            sqlite3 "$_db2" \
              "ALTER TABLE users ADD COLUMN referral_code TEXT;" 2>/dev/null || true
            sqlite3 "$_db2" \
              "ALTER TABLE users ADD COLUMN referred_by INTEGER;" 2>/dev/null || true
            sqlite3 "$_db2" \
              "CREATE TABLE IF NOT EXISTS plans (
                 id INTEGER PRIMARY KEY AUTOINCREMENT,
                 name TEXT NOT NULL,
                 traffic_gb INTEGER NOT NULL DEFAULT 0,
                 duration_days INTEGER NOT NULL DEFAULT 30,
                 price_usdt REAL NOT NULL,
                 limit_ip INTEGER NOT NULL DEFAULT 0,
                 inbound_ids TEXT NOT NULL DEFAULT '',
                 is_active INTEGER NOT NULL DEFAULT 1,
                 sort_order INTEGER NOT NULL DEFAULT 0,
                 created_at TEXT DEFAULT (datetime('now')),
                 updated_at TEXT DEFAULT (datetime('now'))
               );" 2>/dev/null || true
            sqlite3 "$_db2" \
              "CREATE TABLE IF NOT EXISTS pending_actions (
                 id INTEGER PRIMARY KEY AUTOINCREMENT,
                 type TEXT NOT NULL,
                 payload TEXT NOT NULL DEFAULT '{}',
                 created_at TEXT DEFAULT (datetime('now'))
               );" 2>/dev/null || true
            sqlite3 "$_db2" \
              "CREATE TABLE IF NOT EXISTS admin_settings (
                 key TEXT PRIMARY KEY,
                 value TEXT NOT NULL DEFAULT ''
               );" 2>/dev/null || true
            _ok "Migrations applied (existing columns skipped — that's OK)."
          else
            _warn "sqlite3 not installed. Run: apt install sqlite3"
          fi
          _press ;;
        3)
          local _db3; _db3=$(_find_sqlite_db)
          [[ -z "$_db3" ]] && { _err "DB not found."; _press; continue; }
          local _dst="/root/nexora_sqlite_$(date +%Y%m%d_%H%M).db"
          cp "$_db3" "$_dst" && chmod 600 "$_dst" && _ok "Backed up: $_dst" || _err "Backup failed."
          _press ;;
        4)
          local _db4; _db4=$(_find_sqlite_db)
          [[ -z "$_db4" ]] && { _err "DB not found."; _press; continue; }
          if command -v sqlite3 &>/dev/null; then
            _info "Opening SQLite shell. Type .quit to exit."
            sqlite3 "$_db4"
          else
            _err "sqlite3 not installed. Run: apt install sqlite3"
          fi
          _press ;;
        5)
          local _db5; _db5=$(_find_sqlite_db)
          [[ -z "$_db5" ]] && { _err "DB not found."; _press; continue; }
          if command -v sqlite3 &>/dev/null; then
            echo ""
            echo -e "  ${BOLD}Last 10 users:${RESET}"
            sqlite3 -column -header "$_db5" \
              "SELECT telegram_id, username, first_name, is_admin, created_at FROM users ORDER BY created_at DESC LIMIT 10;" 2>/dev/null
          else
            _err "sqlite3 not installed."
          fi
          _press ;;
        6)
          local _db6; _db6=$(_find_sqlite_db)
          [[ -z "$_db6" ]] && { _err "DB not found."; _press; continue; }
          if command -v sqlite3 &>/dev/null; then
            echo ""
            local total; total=$(sqlite3 "$_db6" "SELECT COUNT(*) FROM subscriptions;" 2>/dev/null || echo 0)
            local active; active=$(sqlite3 "$_db6" "SELECT COUNT(*) FROM subscriptions WHERE status='active';" 2>/dev/null || echo 0)
            local expired; expired=$(sqlite3 "$_db6" "SELECT COUNT(*) FROM subscriptions WHERE status='expired';" 2>/dev/null || echo 0)
            local pending; pending=$(sqlite3 "$_db6" "SELECT COUNT(*) FROM payments WHERE status IN ('awaiting_review','waiting','confirming');" 2>/dev/null || echo 0)
            local tickets; tickets=$(sqlite3 "$_db6" "SELECT COUNT(*) FROM tickets WHERE status IN ('open','in_progress');" 2>/dev/null || echo 0)
            echo -e "  ${BOLD}Subscriptions:${RESET}"
            echo -e "  Total: $total   Active: ${GREEN}$active${RESET}   Expired: ${YELLOW}$expired${RESET}"
            echo -e "  Pending Payments: ${YELLOW}$pending${RESET}    Open Tickets: ${CYAN}$tickets${RESET}"
          else
            _err "sqlite3 not installed."
          fi
          _press ;;
        0) return ;;
        *) _warn "Invalid option." ;;
      esac
    fi
  done
}

# ────────────────────────────────────────────────────────────────
#  [4] Backup & Restore — helpers
# ────────────────────────────────────────────────────────────────

# بک‌آپ امن SQLite — از sqlite3 .backup استفاده می‌کند که
# حتی در حین اجرای ربات هم safe است (WAL checkpoint + shared lock)
_backup_sqlite_safe() {
  local dst="$1"
  local _db; _db=$(_find_sqlite_db)
  if [[ -z "$_db" ]]; then
    _warn "SQLite DB not found — bot may not have started yet."
    return 1
  fi
  if command -v sqlite3 &>/dev/null; then
    # sqlite3 .backup تضمین می‌کند که DB در حال تراکنش هم درست کپی می‌شود
    sqlite3 "$_db" ".backup '$dst'" 2>/dev/null \
      && _ok "DB (SQLite safe backup): $dst" \
      || { _err "sqlite3 .backup failed — falling back to cp"; cp "$_db" "$dst" && _ok "DB (cp fallback): $dst" || return 1; }
  else
    # اگه sqlite3 نصب نیست، با cp معمولی (ریسک جزئی در حین نوشتن)
    _warn "sqlite3 not installed — using cp (install: apt install sqlite3 for safe backup)"
    cp "$_db" "$dst" && _ok "DB (SQLite): $dst" || return 1
  fi
}

_backup_ssl() {
  local ts="$1"
  local dst="/root/nexora_ssl_backup_${ts}.tar.gz"
  if [[ ! -d /etc/letsencrypt ]]; then
    _info "No SSL certs (/etc/letsencrypt missing) — skipping."
    return 0
  fi
  tar -czf "$dst" /etc/letsencrypt/ 2>/dev/null \
    && _ok "SSL certs: $dst" \
    || { _err "SSL backup failed."; return 1; }
}

_backup_env() {
  local ts="$1"
  local _backed=0
  # بک‌آپ bot/.env
  if [[ -f "$ENV_FILE" ]]; then
    local dst="/root/nexora_env_backup_${ts}.env"
    cp "$ENV_FILE" "$dst" && chmod 600 "$dst" && _ok "bot/.env: $dst" && (( _backed++ )) || _err "bot/.env backup failed."
  else
    _warn "bot/.env not found — skipping."
  fi
  # بک‌آپ panel/.env.local — شامل پسورد پنل و همه تنظیمات
  if [[ -f "$PANEL_ENV_LOCAL" ]]; then
    local dst2="/root/nexora_panel_env_backup_${ts}.env"
    cp "$PANEL_ENV_LOCAL" "$dst2" && chmod 600 "$dst2" \
      && _ok "panel/.env.local: $dst2" && (( _backed++ )) || _err "panel/.env.local backup failed."
  fi
  (( _backed > 0 )) || { _warn "No env files backed up."; return 1; }
}

_backup_nginx() {
  local ts="$1"
  local _backed=0
  for _conf in \
    "/etc/nginx/conf.d/nexora-webhook.conf" \
    "/etc/nginx/conf.d/nexora-panel.conf"; do
    [[ -f "$_conf" ]] || continue
    local _name; _name=$(basename "$_conf" .conf)
    local dst="/root/nexora_nginx_${_name}_backup_${ts}.conf"
    cp "$_conf" "$dst" && _ok "nginx ${_name}: $dst" && (( _backed++ )) || true
  done
  (( _backed == 0 )) && _info "No nginx nexora configs found — skipping."
}

_backup_full() {
  local ts; ts=$(date +%Y%m%d_%H%M%S)
  echo ""
  echo -e "  ${BOLD}━━━ Full Backup — ${ts} ━━━${RESET}"
  echo ""

  # 1 — Database
  _info "[1/4] Database..."
  if _use_postgres; then
    local dump="/root/nexora_pgdump_${ts}.sql"
    _require_compose
    _dc exec -T db pg_dump -U botuser vpn_bot > "$dump" \
      && _ok "PostgreSQL: $dump" \
      || _err "pg_dump failed."
  else
    local db_dst="/root/nexora_sqlite_${ts}.db"
    _backup_sqlite_safe "$db_dst"
  fi

  # 2 — SSL certs
  _info "[2/4] SSL certificates..."
  _backup_ssl "$ts"

  # 3 — Env files (bot + panel)
  _info "[3/4] Config files (.env / .env.local)..."
  _backup_env "$ts"

  # 4 — nginx configs
  _info "[4/4] nginx configs..."
  _backup_nginx "$ts"

  echo ""
  echo -e "  ${GREEN}${BOLD}✔  Full backup complete!${RESET}"
  echo -e "  ${DIM}All files saved to /root/nexora_*_${ts}.*${RESET}"
  echo ""
  # نمایش فایل‌های بک‌آپ این اجرا
  ls -lh /root/nexora_*_${ts}.* 2>/dev/null | awk '{printf "  %s %s\n", $5, $NF}'
}

_menu_backup() {
  while true; do
    _banner
    echo -e "  ${BOLD}💾  Backup & Restore${RESET}"
    _line
    echo -e "  ${CYAN}${BOLD}  ── BACKUP ──────────────────────────────────${RESET}"
    echo -e "  ${BOLD}[1]${RESET}  Full backup       (DB + SSL + .env + panel env + nginx)"
    if _use_postgres; then
      echo -e "  ${BOLD}[2]${RESET}  Database only     (PostgreSQL dump)"
    else
      echo -e "  ${BOLD}[2]${RESET}  Database only     (SQLite — safe even while bot runs)"
    fi
    echo -e "  ${BOLD}[3]${RESET}  SSL certs only"
    echo -e "  ${BOLD}[4]${RESET}  Config only       (bot/.env + panel/.env.local)"
    echo -e "  ${BOLD}[5]${RESET}  List backup files"
    echo -e "  ${BOLD}[6]${RESET}  Cleanup old backups  (keep last 5 of each type)"
    echo ""
    echo -e "  ${CYAN}${BOLD}  ── RESTORE ─────────────────────────────────${RESET}"
    if _use_postgres; then
      echo -e "  ${BOLD}[7]${RESET}  Restore PostgreSQL DB  (from .sql dump)"
    else
      echo -e "  ${BOLD}[7]${RESET}  Restore SQLite DB      (from backup file)"
    fi
    echo -e "  ${BOLD}[8]${RESET}  Restore bot .env       (from backup file)"
    echo -e "  ${BOLD}[9]${RESET}  Restore panel .env.local  (from backup file)"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      # ── BACKUP ─────────────────────────────────────────────
      1) _backup_full; _press ;;
      2)
        local _ts2; _ts2=$(date +%Y%m%d_%H%M%S)
        if _use_postgres; then
          local dump="/root/nexora_pgdump_${_ts2}.sql"
          _require_compose
          _info "Dumping PostgreSQL to $dump ..."
          _dc exec -T db pg_dump -U botuser vpn_bot > "$dump" \
            && _ok "Saved: $dump  ($(ls -lh "$dump" | awk '{print $5}'))" \
            || _err "pg_dump failed."
        else
          local db_dst="/root/nexora_sqlite_${_ts2}.db"
          _backup_sqlite_safe "$db_dst"
        fi
        _press ;;
      3)
        local _ts3; _ts3=$(date +%Y%m%d_%H%M%S)
        _backup_ssl "$_ts3"; _press ;;
      4)
        local _ts4; _ts4=$(date +%Y%m%d_%H%M%S)
        _backup_env "$_ts4"; _press ;;
      5)
        echo ""
        echo -e "  ${BOLD}Nexora backup files in /root/:${RESET}"
        echo ""
        local _any=0
        for _ext in "*.db" "*.sql" "*.tar.gz" "*.env" "*.conf"; do
          local _files; _files=$(ls /root/nexora_${_ext} 2>/dev/null || true)
          [[ -z "$_files" ]] && continue
          echo -e "  ${DIM}--- ${_ext} ---${RESET}"
          ls -lht /root/nexora_${_ext} 2>/dev/null | awk '{printf "  %s  %s  %s\n", $6, $7, $NF}' || true
          _any=1
        done
        (( _any == 0 )) && _warn "No backup files found in /root/." || true
        _press ;;
      6)
        echo ""
        _info "Keeping last 5 of each backup type, deleting older ones..."
        local _deleted=0
        for _pattern in "nexora_sqlite_*.db" "nexora_pgdump_*.sql" \
                         "nexora_ssl_backup_*.tar.gz" "nexora_env_backup_*.env" \
                         "nexora_panel_env_backup_*.env" "nexora_nginx_*.conf"; do
          local _old_files
          # ls -t = newest first, tail -n +6 = skip newest 5, delete rest
          _old_files=$(ls -t /root/${_pattern} 2>/dev/null | tail -n +6 || true)
          if [[ -n "$_old_files" ]]; then
            while IFS= read -r _f; do
              rm -f "$_f" && _ok "Deleted: $_f" && (( _deleted++ )) || true
            done <<< "$_old_files"
          fi
        done
        (( _deleted == 0 )) && _ok "Nothing to clean up." || _ok "$_deleted old backup(s) deleted."
        _press ;;

      # ── RESTORE ─────────────────────────────────────────────
      7)
        if _use_postgres; then
          # PostgreSQL restore از فایل .sql
          echo ""
          echo -e "  ${BOLD}PostgreSQL dump files in /root/:${RESET}"
          local _pgfiles=(); mapfile -t _pgfiles < <(ls -t /root/nexora_pgdump_*.sql 2>/dev/null || true)
          if [[ ${#_pgfiles[@]} -eq 0 ]]; then
            _warn "No .sql dump files found. Run backup [2] first."; _press; continue
          fi
          for i in "${!_pgfiles[@]}"; do
            local _sz; _sz=$(ls -lh "${_pgfiles[$i]}" | awk '{print $5}')
            echo -e "  ${BOLD}[$((i+1))]${RESET}  ${_pgfiles[$i]}  ${DIM}(${_sz})${RESET}"
          done
          echo ""
          read -rp "  Select dump number (0 to cancel): " _pick
          [[ "$_pick" == "0" || -z "$_pick" ]] && continue
          if [[ "$_pick" =~ ^[0-9]+$ ]] && (( _pick >= 1 && _pick <= ${#_pgfiles[@]} )); then
            local _chosen_pg="${_pgfiles[$((_pick-1))]}"
            _warn "This will DROP and recreate all tables in vpn_bot database!"
            read -rp "  Type YES to confirm: " _conf_pg
            if [[ "$_conf_pg" == "YES" ]]; then
              _require_compose
              _info "Stopping bot container..."
              _dc stop bot 2>/dev/null || true
              _info "Restoring PostgreSQL from $_chosen_pg ..."
              # Drop + recreate schema, then restore
              _dc exec -T db psql -U botuser -d postgres \
                -c "DROP DATABASE IF EXISTS vpn_bot; CREATE DATABASE vpn_bot OWNER botuser;" 2>/dev/null || true
              _dc exec -T db psql -U botuser -d vpn_bot < "$_chosen_pg" \
                && _ok "PostgreSQL restore complete." \
                || _err "PostgreSQL restore failed."
              _info "Starting bot container..."
              _dc up -d bot
              _ok "Bot restarted."
            else
              _warn "Cancelled."
            fi
          else
            _warn "Invalid selection."
          fi
          _press

        else
          # SQLite restore
          local _live; _live=$(_find_sqlite_db)
          [[ -z "$_live" ]] && { _err "Live DB path not found."; _press; continue; }
          echo ""
          echo -e "  ${BOLD}SQLite backup files in /root/:${RESET}"
          local _bfiles=(); mapfile -t _bfiles < <(ls -t /root/nexora_sqlite_*.db 2>/dev/null || true)
          if [[ ${#_bfiles[@]} -eq 0 ]]; then
            _warn "No backup files found. Run backup [2] first."; _press; continue
          fi
          for i in "${!_bfiles[@]}"; do
            local _sz; _sz=$(ls -lh "${_bfiles[$i]}" | awk '{print $5}')
            echo -e "  ${BOLD}[$((i+1))]${RESET}  ${_bfiles[$i]}  ${DIM}(${_sz})${RESET}"
          done
          echo ""
          read -rp "  Select backup number (0 to cancel): " _pick
          [[ "$_pick" == "0" || -z "$_pick" ]] && continue
          if [[ "$_pick" =~ ^[0-9]+$ ]] && (( _pick >= 1 && _pick <= ${#_bfiles[@]} )); then
            local _chosen="${_bfiles[$((_pick-1))]}"
            echo ""
            _warn "This will REPLACE the live DB: ${_live}"
            _warn "The bot container will be STOPPED and restarted automatically."
            read -rp "  Type YES to confirm: " _conf
            if [[ "$_conf" == "YES" ]]; then
              # 1. Auto-backup فعلی قبل از restore
              local _auto_bak="${_live}.before_restore_$(date +%s)"
              _info "Auto-backing up current DB → $_auto_bak"
              if command -v sqlite3 &>/dev/null; then
                sqlite3 "$_live" ".backup '${_auto_bak}'" 2>/dev/null || cp "$_live" "$_auto_bak"
              else
                cp "$_live" "$_auto_bak"
              fi
              _ok "Current DB saved."
              # 2. Stop کردن ربات — ضروری برای SQLite file lock
              _info "Stopping bot container (required for SQLite restore)..."
              _require_compose && _dc stop bot 2>/dev/null || true
              sleep 2
              # 3. Copy بک‌آپ به مسیر live
              cp "$_chosen" "$_live" \
                && _ok "Restore complete: $(_live)" \
                || { _err "Restore failed!"; _info "Restoring original..."; cp "$_auto_bak" "$_live"; _ok "Original restored."; _press; continue; }
              # 4. Start کردن ربات
              _info "Starting bot container..."
              _dc up -d bot
              _ok "Bot restarted — restore successful!"
            else
              _warn "Cancelled."
            fi
          else
            _warn "Invalid selection."
          fi
          _press
        fi ;;

      8)
        # Restore bot .env
        echo ""
        echo -e "  ${BOLD}bot/.env backup files in /root/:${RESET}"
        local _envfiles=(); mapfile -t _envfiles < <(ls -t /root/nexora_env_backup_*.env 2>/dev/null || true)
        if [[ ${#_envfiles[@]} -eq 0 ]]; then
          _warn "No .env backup files found. Run backup [4] first."; _press; continue
        fi
        for i in "${!_envfiles[@]}"; do
          echo -e "  ${BOLD}[$((i+1))]${RESET}  ${_envfiles[$i]}"
        done
        echo ""
        read -rp "  Select (0 to cancel): " _pick
        [[ "$_pick" == "0" || -z "$_pick" ]] && continue
        if [[ "$_pick" =~ ^[0-9]+$ ]] && (( _pick >= 1 && _pick <= ${#_envfiles[@]} )); then
          local _chosen_env="${_envfiles[$((_pick-1))]}"
          _warn "This will REPLACE $ENV_FILE"
          read -rp "  Type YES to confirm: " _ce
          if [[ "$_ce" == "YES" ]]; then
            cp "$ENV_FILE" "$ENV_FILE.before_restore_$(date +%s)" 2>/dev/null || true
            cp "$_chosen_env" "$ENV_FILE" && chmod 600 "$ENV_FILE" \
              && _ok "bot/.env restored." \
              || _err "Restore failed."
            read -rp "  Recreate bot container to apply new .env? (Y/n): " _rr; _rr="${_rr:-Y}"
            [[ "$_rr" =~ ^[Yy]$ ]] && _require_compose && _dc up -d --force-recreate bot && _ok "Bot restarted."
          else
            _warn "Cancelled."
          fi
        fi
        _press ;;

      9)
        # Restore panel .env.local
        echo ""
        echo -e "  ${BOLD}panel .env.local backup files in /root/:${RESET}"
        local _penvfiles=(); mapfile -t _penvfiles < <(ls -t /root/nexora_panel_env_backup_*.env 2>/dev/null || true)
        if [[ ${#_penvfiles[@]} -eq 0 ]]; then
          _warn "No panel .env.local backup files found. Run backup [4] first."; _press; continue
        fi
        for i in "${!_penvfiles[@]}"; do
          echo -e "  ${BOLD}[$((i+1))]${RESET}  ${_penvfiles[$i]}"
        done
        echo ""
        read -rp "  Select (0 to cancel): " _pick
        [[ "$_pick" == "0" || -z "$_pick" ]] && continue
        if [[ "$_pick" =~ ^[0-9]+$ ]] && (( _pick >= 1 && _pick <= ${#_penvfiles[@]} )); then
          local _chosen_penv="${_penvfiles[$((_pick-1))]}"
          _warn "This will REPLACE $PANEL_ENV_LOCAL"
          read -rp "  Type YES to confirm: " _cpe
          if [[ "$_cpe" == "YES" ]]; then
            cp "$PANEL_ENV_LOCAL" "$PANEL_ENV_LOCAL.before_restore_$(date +%s)" 2>/dev/null || true
            cp "$_chosen_penv" "$PANEL_ENV_LOCAL" && chmod 600 "$PANEL_ENV_LOCAL" \
              && _ok "panel .env.local restored." \
              || _err "Restore failed."
            read -rp "  Restart panel service to apply? (Y/n): " _rp; _rp="${_rp:-Y}"
            [[ "$_rp" =~ ^[Yy]$ ]] && systemctl restart "$PANEL_SYSTEMD_SERVICE" 2>/dev/null \
              && _ok "Panel restarted." || _warn "Could not restart panel."
          else
            _warn "Cancelled."
          fi
        fi
        _press ;;

      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

