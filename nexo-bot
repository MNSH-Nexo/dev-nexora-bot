          _env_set "$PANEL_ENV_KEY_PORT"    "$_wport"
          echo ""
          echo -e "  ${GREEN}${BOLD}✔  Web Panel is ready!${RESET}"
          _line
          local _my_ip; _my_ip=$(curl -s4 --max-time 5 ifconfig.me 2>/dev/null || echo "YOUR_IP")
          _info "URL: http://${_my_ip}:${_wport}${_wpath}"
          _info "User: ${_wuser}"
          _warn "Keep the web path secret!"
          _press ;;
        0) return ;;
        *) _warn "Invalid option." ;;
      esac
    else
      case $ch in
        1)
          _write_panel_env \
            "$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PATH" "/nexora")" \
            "$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_USER" "admin")" \
            "$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PASS" "")" \
            "$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")" \
            "false"
          _env_set "$PANEL_ENV_KEY_ENABLED" "false"
          systemctl stop "$PANEL_SYSTEMD_SERVICE" 2>/dev/null || true
          _ok "Web Panel disabled." && _press ;;
        2)
          read -rp "  New username [Enter to keep]: " _wu
          [[ -n "$_wu" ]] && _env_set "WEB_PANEL_USER" "$_wu" "$PANEL_ENV_LOCAL" && _env_set "$PANEL_ENV_KEY_USER" "$_wu"
          echo -e "  ${BOLD}New password${RESET}  ${DIM}(min 8 chars, Enter to skip)${RESET}"
          read -rsp "  Password: " _wp; echo ""
          if (( ${#_wp} >= 8 )); then
            read -rsp "  Confirm: " _wp2; echo ""
            if [[ "$_wp" == "$_wp2" ]]; then
              _env_set "WEB_PANEL_PASS" "$_wp" "$PANEL_ENV_LOCAL"
              _env_set "$PANEL_ENV_KEY_PASS" "$_wp"
              _panel_apply_env
              _ok "Credentials updated."
            else
              _err "Passwords do not match."
            fi
          elif [[ -n "$_wp" ]]; then
            _warn "Password too short — not changed."
          fi
          _press ;;
        3)
          read -rp "  New web path (e.g. /secretadmin): " _newpath
          _newpath="/${_newpath#/}"
          _env_set "WEB_PANEL_PATH" "$_newpath" "$PANEL_ENV_LOCAL"
          _env_set "$PANEL_ENV_KEY_PATH" "$_newpath"
          _panel_apply_env
          _ok "Web path updated: $_newpath" && _press ;;
        4)
          local _cur_port; _cur_port=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")
          read -rp "  New port [current: ${_cur_port}]: " _np
          if [[ -n "$_np" ]]; then
            _env_set "WEB_PANEL_PORT" "$_np" "$PANEL_ENV_LOCAL"
            _env_set "$PANEL_ENV_KEY_PORT" "$_np"
            _panel_apply_env
            _ok "Port updated → panel restarted."
          fi
          _press ;;
        5)
          local _pp; _pp=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PATH" "/nexora")
          local _pport; _pport=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")
          local _panel_dom; _panel_dom=$(_env_read "$ENV_FILE" "WEB_PANEL_DOMAIN" "")
          local _my_ip2; _my_ip2=$(curl -s4 --max-time 5 ifconfig.me 2>/dev/null || echo "YOUR_IP")
          echo ""
          _info "HTTP  : http://${_my_ip2}:${_pport}${_pp}"
          [[ -n "$_panel_dom" ]] && _info "HTTPS : https://${_panel_dom}${_pp}"
          _press ;;
        6)
          systemctl restart "$PANEL_SYSTEMD_SERVICE" 2>/dev/null \
            && _ok "Panel restarted." \
            || _err "Restart failed. Check: journalctl -u $PANEL_SYSTEMD_SERVICE -n 20"
          _press ;;
        7)
          echo ""
          _info "Last 50 lines of panel logs:"
          echo ""
          journalctl -u "$PANEL_SYSTEMD_SERVICE" -n 50 --no-pager 2>/dev/null \
            || _warn "journalctl not available."
          _press ;;
        8)
          _info "Syncing bot .env vars to panel .env.local..."
          local _wpath_s; _wpath_s=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PATH" "/nexora")
          local _wuser_s; _wuser_s=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_USER" "admin")
          local _wpass_s; _wpass_s=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PASS" "")
          local _wport_s; _wport_s=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")
          _write_panel_env "$_wpath_s" "$_wuser_s" "$_wpass_s" "$_wport_s" "true"
          _panel_apply_env
          _ok "Sync complete — panel restarted." && _press ;;
        9)
          echo ""
          _warn "This will rebuild the panel from source. Current settings will be preserved."
          read -rp "  Continue? (y/N): " _conf
          [[ "$_conf" =~ ^[Yy]$ ]] || { _press; continue; }
          local _wpath_r; _wpath_r=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PATH" "/nexora")
          local _wuser_r; _wuser_r=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_USER" "admin")
          local _wpass_r; _wpass_r=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PASS" "")
          local _wport_r; _wport_r=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")
          _panel_full_install "$_wpath_r" "$_wuser_r" "$_wpass_r" "$_wport_r" \
            && _ok "Rebuild complete." || _err "Rebuild failed."
          _press ;;
        0) return ;;
        *) _warn "Invalid option." ;;
      esac
    fi
  done
}

# ────────────────────────────────────────────────────────────────
#  [6] Uninstall
# ────────────────────────────────────────────────────────────────
_menu_uninstall() {
  _banner
  echo -e "  ${RED}${BOLD}⚠️   UNINSTALL — Complete Removal${RESET}"
  _line
  echo -e "  ${YELLOW}This will permanently delete:${RESET}"
  echo -e "  • Docker containers  (nexora_bot, nexora_postgres)"
  echo -e "  • Docker image       (nexora-vpn-bot)"
  echo -e "  • Docker volumes     (all data & logs)"
  echo -e "  • Bot directory      ($BOT_DIR)"
  echo -e "  • nexo-bot command   (/usr/local/bin/nexo-bot)"
  echo -e "  • Web panel          ($PANEL_DIR)"
  echo -e "  • Panel service      (systemd: ${PANEL_SYSTEMD_SERVICE})"
  echo -e "  • nginx config       (/etc/nginx/conf.d/nexora-panel.conf)"
  echo ""
  echo -e "  ${RED}${BOLD}THIS CANNOT BE UNDONE.${RESET}"
  _line
  read -rp "  Type  DELETE  to confirm: " confirm
  [[ "$confirm" != "DELETE" ]] && { _warn "Cancelled."; _press; return; }
  echo ""
  _info "Stopping containers..."
  docker compose -f "$COMPOSE_FILE" --profile postgres down -v --remove-orphans 2>/dev/null || true
  _info "Removing image..."
  docker rmi nexora-vpn-bot:latest 2>/dev/null || true
  if systemctl is-active "$PANEL_SYSTEMD_SERVICE" &>/dev/null; then
    systemctl stop "$PANEL_SYSTEMD_SERVICE" 2>/dev/null || true
  fi
  if systemctl is-enabled "$PANEL_SYSTEMD_SERVICE" &>/dev/null; then
    systemctl disable "$PANEL_SYSTEMD_SERVICE" 2>/dev/null || true
  fi
  if [[ -f "/etc/systemd/system/${PANEL_SYSTEMD_SERVICE}.service" ]]; then
    rm -f "/etc/systemd/system/${PANEL_SYSTEMD_SERVICE}.service"
    systemctl daemon-reload 2>/dev/null || true
  fi
  [[ -d "$PANEL_DIR" ]] && rm -rf "$PANEL_DIR" && _ok "Panel directory removed."
  [[ -f "/etc/nginx/conf.d/nexora-panel.conf" ]] && rm -f "/etc/nginx/conf.d/nexora-panel.conf" \
    && systemctl is-active nginx &>/dev/null && nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null || true
  local _panel_port; _panel_port=$(_env_read "$ENV_FILE" "WEB_PANEL_PORT" "")
  if [[ -n "$_panel_port" ]]; then
    command -v ufw &>/dev/null && ufw status 2>/dev/null | grep -q "active" \
      && ufw delete allow "${_panel_port}/tcp" &>/dev/null && _ok "UFW: port removed." || true
    command -v firewall-cmd &>/dev/null \
      && firewall-cmd --permanent --remove-port="${_panel_port}/tcp" &>/dev/null \
      && firewall-cmd --reload &>/dev/null && _ok "firewalld: port removed." || true
  fi
  _info "Removing bot directory..."
  rm -rf "$BOT_DIR"
  _info "Removing nexo-bot command..."
  rm -f /usr/local/bin/nexo-bot
  echo ""
  echo -e "  ${GREEN}${BOLD}✔  Nexora VPN Bot fully removed.${RESET}"
  echo ""
  exit 0
}

