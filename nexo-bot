_webhook_pick_domain() {
  PICKED_DOMAIN=""
  local domains_arr=()
  if [[ -d /etc/letsencrypt/live ]]; then
    while IFS= read -r d; do
      [[ "$d" == "README" || -z "$d" ]] && continue
      domains_arr+=("$d")
    done < <(ls /etc/letsencrypt/live/ 2>/dev/null || true)
  fi
  if [[ ${#domains_arr[@]} -gt 0 ]]; then
    echo -e "\n  ${BOLD}SSL domains:${RESET}"
    for i in "${!domains_arr[@]}"; do
      echo -e "  ${BOLD}[$((i+1))]${RESET}  ${domains_arr[$i]}"
    done
    echo -e "  ${BOLD}[m]${RESET}  Enter manually"
    echo ""
    read -rp "  Select: " _pick
    if [[ "$_pick" =~ ^[0-9]+$ ]] && (( _pick >= 1 && _pick <= ${#domains_arr[@]} )); then
      PICKED_DOMAIN="${domains_arr[$((_pick-1))]}"
    else
      read -rp "  Domain: " PICKED_DOMAIN
    fi
  else
    _warn "No SSL certs found. Use SSL Manager [7] first."
    read -rp "  Enter domain manually: " PICKED_DOMAIN
  fi
  PICKED_DOMAIN="${PICKED_DOMAIN// /}"
}

_menu_webhook() {
  while true; do
    _banner
    echo -e "  ${BOLD}🔗  Webhook Manager${RESET}"
    _line
