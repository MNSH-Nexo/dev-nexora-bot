          echo ""
          local _suggested_path; _suggested_path=$(_gen_webpath)
          echo -e "  ${BOLD}Web Path${RESET}  ${DIM}(security key — random suggestion below)${RESET}"
          echo -e "  ${DIM}Suggestion: ${CYAN}${_suggested_path}${RESET}  ${DIM}(Enter to use or type your own)${RESET}"
          read -rp "  Web Path: " _wpath
          _wpath="${_wpath:-$_suggested_path}"
          _wpath="/${_wpath#/}"
          read -rp "  Admin username [default: admin]: " _wuser
          _wuser="${_wuser:-admin}"
          echo -e "  ${BOLD}Admin password${RESET}  ${DIM}(min 8 characters)${RESET}"
          while true; do
            read -rsp "  Password: " _wpass; echo ""
            (( ${#_wpass} >= 8 )) && break
            _warn "Password must be at least 8 characters."
          done
          read -rsp "  Confirm password: " _wpass2; echo ""
          if [[ "$_wpass" != "$_wpass2" ]]; then _err "Passwords do not match."; _press; continue; fi
          read -rp "  Port [default: 3000]: " _wport; _wport="${_wport:-3000}"
          _panel_full_install "$_wpath" "$_wuser" "$_wpass" "$_wport" || { _err "Installation failed."; _press; continue; }
          _env_set "$PANEL_ENV_KEY_ENABLED" "true"
          _env_set "$PANEL_ENV_KEY_PATH"    "$_wpath"
