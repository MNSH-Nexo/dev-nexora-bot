# ────────────────────────────────────────────────────────────────
#  [7] SSL Manager
# ────────────────────────────────────────────────────────────────
_menu_ssl() {
  while true; do
    _banner
    echo -e "  ${BOLD}🔒  SSL Manager — Let's Encrypt${RESET}"
    _line
    _ssl_list_domains
    echo ""
    echo -e "  ${BOLD}[1]${RESET}  Get new certificate      (for bot webhooks)"
    echo -e "  ${BOLD}[2]${RESET}  Renew all certificates   (certbot renew)"
    echo -e "  ${BOLD}[3]${RESET}  Show certificate details"
    echo -e "  ${BOLD}[4]${RESET}  ${GREEN}Get certificate for Web Panel${RESET}  (HTTPS)"
    echo -e "  ${BOLD}[0]${RESET}  ${DIM}Back${RESET}"
    _line
    read -rp "  Choose: " ch
    case $ch in
      1)
        read -rp "  Domain: " _domain; _domain="${_domain// /}"
        [[ -z "$_domain" ]] && { _warn "Domain cannot be empty."; _press; continue; }
        read -rp "  Email [optional, Enter to skip]: " _email
        [[ -z "$_email" ]] && _email="noreply@${_domain}" && _info "Using auto email."
        _ssl_install_certbot || { _press; continue; }
        _ssl_get_cert "$_domain" "$_email" || { _press; continue; }
        read -rp "  Setup nginx HTTPS proxy for webhooks? (Y/n): " _nyn; _nyn="${_nyn:-Y}"
        [[ "$_nyn" =~ ^[Yy]$ ]] && _ssl_setup_nginx_proxy "$_domain"
        _ssl_update_env "$_domain"; _press ;;
      2)
        _info "Renewing certificates..."
        if _ssl_certbot_ok; then
          systemctl is-active nginx &>/dev/null \
            && certbot renew --nginx --quiet 2>&1 | tail -5 \
            || certbot renew --standalone --quiet 2>&1 | tail -5
          _ok "Renewal complete."
        else
          _warn "certbot not installed. Use [1] first."
        fi
        _press ;;
      3)
        echo ""
        _ssl_certbot_ok && certbot certificates 2>/dev/null || _warn "certbot not installed."
        _press ;;
      4)
        read -rp "  Domain for Web Panel: " _pdomain; _pdomain="${_pdomain// /}"
        [[ -z "$_pdomain" ]] && { _warn "Domain cannot be empty."; _press; continue; }
        read -rp "  Email [optional]: " _pemail
        [[ -z "$_pemail" ]] && _pemail="noreply@${_pdomain}"
        _ssl_install_certbot || { _press; continue; }
        _ssl_get_cert "$_pdomain" "$_pemail" || { _press; continue; }
        _env_set "WEB_PANEL_DOMAIN" "$_pdomain"
        read -rp "  Setup nginx HTTPS proxy for web panel? (Y/n): " _pnyn; _pnyn="${_pnyn:-Y}"
        if [[ "$_pnyn" =~ ^[Yy]$ ]]; then
          local _panelport; _panelport=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PORT" "3000")
          local _panelpath; _panelpath=$(_env_read "$PANEL_ENV_LOCAL" "WEB_PANEL_PATH" "/nexora")
          local _nginx_conf="/etc/nginx/conf.d/nexora-panel.conf"
          cat > "$_nginx_conf" <<NGINXEOF
server {
    listen 443 ssl;
    server_name ${_pdomain};
    ssl_certificate     /etc/letsencrypt/live/${_pdomain}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${_pdomain}/privkey.pem;
    location ${_panelpath} {
        proxy_pass http://127.0.0.1:${_panelport};
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
    }
}
server {
    listen 80;
    server_name ${_pdomain};
    return 301 https://\$host\$request_uri;
}
NGINXEOF
          command -v nginx &>/dev/null && nginx -t 2>/dev/null \
            && systemctl reload nginx 2>/dev/null && _ok "nginx HTTPS proxy configured." \
            || _warn "nginx not found or config failed."
        fi
        _ok "SSL ready: https://${_pdomain}${_panelpath:-/nexora}"
        _press ;;
      0) return ;;
      *) _warn "Invalid option." ;;
    esac
  done
}

