        _press ;;
      2)
        echo -e "  ${DIM}Example: https://pay.example.com/webhook/nowpayments${RESET}"
        read -rp "  NOWPayments IPN URL: " _url
        [[ -z "$_url" ]] && { _press; continue; }
        _env_set "NOWPAYMENTS_IPN_URL" "$_url"
        _ok "Updated. Also update your NOWPayments dashboard."
        read -rp "  Restart bot now? (Y/n): " _r; _r="${_r:-Y}"
        [[ "$_r" =~ ^[Yy]$ ]] && _require_compose && _dc up -d --force-recreate bot && _ok "Bot restarted."
        _press ;;
      3)
        echo -e "  ${DIM}Example: https://pay.example.com/webhook/maxelpay${RESET}"
        read -rp "  MaxelPay Webhook URL: " _url
        [[ -z "$_url" ]] && { _press; continue; }
        _env_set "MAXELPAY_WEBHOOK_URL" "$_url"
        _ok "Updated. Also update your MaxelPay dashboard."
        read -rp "  Restart bot now? (Y/n): " _r; _r="${_r:-Y}"
        [[ "$_r" =~ ^[Yy]$ ]] && _require_compose && _dc up -d --force-recreate bot && _ok "Bot restarted."
        _press ;;
      4)
        local _port; _port=$(_env_read "$ENV_FILE" "WEBHOOK_PORT" "9988")
        echo ""
        _info "Testing http://127.0.0.1:${_port}/health ..."
        if curl -sf --max-time 5 "http://127.0.0.1:${_port}/health" &>/dev/null; then
